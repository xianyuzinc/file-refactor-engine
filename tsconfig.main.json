{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "jsx": "react-jsx",
    "types": ["node"],
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/main/**/*", "src/core/**/*"]
}
