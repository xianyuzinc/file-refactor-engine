{
  "name": "file-refactor-engine",
  "version": "0.3.0",
  "description": "Dependency-aware file-system refactoring for Windows projects.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on tcp:5173 dist/main/main.js dist/main/preload.cjs && electron .",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "npm run build && electron-builder --win portable"
  },
  "keywords": [
    "electron",
    "refactor",
    "filesystem",
    "latex",
    "research"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "diff": "^8.0.2",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "local.file-refactor-engine",
    "productName": "File Refactor Engine",
    "icon": "assets/icon.ico",
    "files": [
      "dist/**/*",
      "assets/icon.*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
